{
  "name": "wepi",
  "version": "0.0.1",
  "description": "Minimal POC SDK for chatting with the pi coding agent entirely in the browser, via container2wasm. Ships headless core + React hooks.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./c2w": {
      "types": "./dist/sandbox/c2w.d.ts",
      "import": "./dist/sandbox/c2w.js"
    },
    "./lifo": {
      "types": "./dist/sandbox/lifo.d.ts",
      "import": "./dist/sandbox/lifo.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./webllm": {
      "types": "./dist/engine/webllm.d.ts",
      "import": "./dist/engine/webllm.js"
    },
    "./wllama": {
      "types": "./dist/engine/wllama.d.ts",
      "import": "./dist/engine/wllama.js"
    },
    "./litert": {
      "types": "./dist/engine/litert.d.ts",
      "import": "./dist/engine/litert.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "bin": {
    "wepi-build-image": "./scripts/build-image.mjs",
    "wepi-fetch-assets": "./scripts/fetch-assets.mjs"
  },
  "files": [
    "dist",
    "src",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.1",
    "@earendil-works/pi-agent-core": "0.80.2",
    "@earendil-works/pi-ai": "0.80.2"
  },
  "peerDependencies": {
    "@lifo-sh/core": ">=0.6.0",
    "@litert-lm/core": ">=0.12.0",
    "@mlc-ai/web-llm": ">=0.2.79",
    "@wllama/wllama": ">=3.1.0",
    "react": ">=18",
    "react-dom": ">=18",
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "@lifo-sh/core": {
      "optional": true
    },
    "@litert-lm/core": {
      "optional": true
    },
    "@mlc-ai/web-llm": {
      "optional": true
    },
    "@wllama/wllama": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lifo-sh/core": "^0.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
